# Database
DATABASE_URL="postgresql://user:password@localhost:5432/terenuri_db"

# App URL (for email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Email (nodemailer) — optional, emails logged to console if not set
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_google_app_password
EMAIL_FROM="Invest <your@gmail.com>"

# Cron protection — add same value to Vercel env + vercel.json header
CRON_SECRET=your_random_secret_here
